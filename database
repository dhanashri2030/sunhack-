def get_reading_history(user_id, limit=20):
    conn = get_db()
    cursor = conn.cursor()
    cursor.execute('SELECT * FROM health_readings WHERE user_id = ? ORDER BY timestamp DESC LIMIT ?', (user_id, limit))
    readings = cursor.fetchall()
    conn.close()
