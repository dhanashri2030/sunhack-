# Health reading functions
def save_health_reading(user_id, heart_rate, spo2, temperature, bp_sys, bp_dia, status, risk_score, ai_message):
    conn = get_db()
    cursor = conn.cursor()
    cursor.execute('''
        INSERT INTO health_readings (user_id, heart_rate, spo2, temperature, blood_pressure_sys, blood_pressure_dia, status, risk_score, ai_message)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
    ''', (user_id, heart_rate, spo2, temperature, bp_sys, bp_dia, status, risk_score, ai_message))
    conn.commit()
    reading_id = cursor.lastrowid
    conn.close()
    return reading_id

def get_latest_reading(user_id):
    conn = get_db()
